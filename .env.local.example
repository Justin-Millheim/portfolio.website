# Adobe Web SDK (Alloy) — Edge Network configuration
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
#
# Where to find these values:
#
#   NEXT_PUBLIC_ADOBE_DATASTREAM_ID
#     Adobe Experience Platform Data Collection
#     → Datastreams → select your datastream → copy the "Datastream ID" (a UUID)
#
#   NEXT_PUBLIC_ADOBE_ORG_ID
#     Adobe Admin Console (adminconsole.adobe.com)
#     → Settings → Identity → IMS Organization ID
#     Format: XXXXXXXXXXXXXXXXXXXXXXXX@AdobeOrg

NEXT_PUBLIC_ADOBE_DATASTREAM_ID=your-datastream-uuid-here
NEXT_PUBLIC_ADOBE_ORG_ID=your-org-id@AdobeOrg
